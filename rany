local function createBox(pos, size, title, color)
    local b = Instance.new("Frame", Container)
    b.Size = size
    b.Position = pos
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    applyStyle(b, color or Color3.fromRGB(60, 60, 80))
    
    local tl = Instance.new("TextLabel", b)
    tl.Size = UDim2.new(1, 0, 0.3, 0)
    tl.Text = title
    tl.TextColor3 = color or Color3.fromRGB(200, 200, 220)
    tl.TextScaled = true
    tl.Font = Enum.Font.GothamBold
    tl.BackgroundTransparency = 1
    
    local val = Instance.new("TextLabel", b)
    val.Name = "Value"
    val.Size = UDim2.new(1, -10, 0.6, 0)
    val.Position = UDim2.new(0, 5, 0.35, 0)
