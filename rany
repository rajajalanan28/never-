local function applyStyle(parent, strokeColor)
    Instance.new("UICorner", parent).CornerRadius = UDim.new(0, 15)
    local s = Instance.new("UIStroke", parent)
    s.Thickness = 2
    s.Color = strokeColor or Color3.fromRGB(0, 255, 200)
    s.Transparency = 0.5
end
